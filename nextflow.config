
params {
    id        = 'chorus_sv'      // cohort/run name used in output filenames
    outdir    = 'output'
    ped       = ''      // PED file defining samples and family structure
    bams      = ''      // glob or CSV of input BAM/CRAM files
    ref_fasta = ''      // reference genome FASTA (must be indexed)
    assembly  = 'hg38'  // genome build: hg38 or hg19
    chr_prefix = null   // chromosome prefix: null = auto ('chr' for hg38, '' for hg19)
    callers   = ['MANTA', 'DYSGU', 'SMOOVE', 'DELLY', 'DELLY_CNV', 'CNVNATOR']  // callers to run; order sets merge priority
    apply_filters = ['DYSGU', 'DELLY']  // callers whose BCFs are PASS-filtered (bcftools view -f PASS,.) before MATCHA
    familial  = false   // treat samples grouped by family in PED (joint calling where supported)
    copy_bams = false   // copy BAMs to work dir (needed if input is on slow/remote storage)
    refdir    = 'reference_files'  // storeDir for downloaded reference files (mappability, exclude lists)
    cachedir       = null  // storeDir for cacheable outputs (caller calls); Set to a persistent path outside the work dir. Note that parameter changes will not flow through.
    caller_vcf_dir = null  // if set, per-sample per-caller BCFs are copied to <caller_vcf_dir>/<CALLER>/ for each active caller
    cnvnator_bin_size           = 1000   // CNVnator bin size (bp)
    cnvnator_exclude_overlap    = 0.7    // drop CNVnator calls with > this fraction of their length overlapping an exclude region
    chrs      = 'auto'  // chromosomes to process; null = no restriction, 'auto' = autosomes + X/Y with chr_prefix, or a List of names
    min_mapq  = 15      // minimum mapping quality; applies to DYSGU (--mq) and DELLY/DELLY_CNV (-q); manta uses 15 internally but does not expose this via CLI
    delly_cnv_max_dels   = 2000  // if set, cap DELLY_CNV DEL callsets to top N by QUAL (post-CNV-normalisation). Recommended.
    delly_cnv_max_dups   = 1000   // if set, cap DELLY_CNV DUP callsets to top N by QUAL (post-CNV-normalisation). Recommended.

    duphold              = true   // run duphold filtering between per-sample collapse and cohort merge (both branches)
    duphold_min_size     = 1000   // bp; only DEL/DUP >= this size are run through duphold
    duphold_max_dels     = 4000   // if set, cap DELs passing duphold by tightening DHFFC so at most N DELs pass
    duphold_max_dups     = 1000   // if set, cap DUPs passing duphold by tightening DHBFC so at most N DUPs pass

    duphold_del_dhffc    = 0.75   // exclude DELs with FMT/DHFFC[0] above this threshold
    duphold_dup_dhbfc    = 1.25   // exclude DUPs with FMT/DHBFC[0] below this threshold
    
    matcha               = false  // run MATCHA merge branch
    matcha_min_jaccard   = 0.75   // minimum Jaccard similarity for matcha collapse/merge
    matcha_sample_filter = 'FILTER="PASS" || INFO/N_CALLERS>1' // keep events detected by ≥2 callers in this sample (or PASS)
    matcha_cohort_filter = 'INFO/N_CALLERS>1' // keep events detected by ≥2 callers in at least one sample
    
    svdb                  = true  // run SVDB merge branch
    svdb_overlap          = 0.75   // --overlap: min reciprocal overlap fraction for merging (both stages)
    svdb_bnd_distance     = 50   // --bnd_distance: max bp distance between precise breakpoints (both stages)
    svdb_sample_filter    = 'FOUNDBY>1'  // keep events detected by ≥2 callers in this sample (SVDB INFO/FOUNDBY = caller count)
    svdb_cohort_filter    = null  // bcftools -i filter applied after cohort merge (null = no filter)
    svdb_info_keep        = ['SVTYPE', 'SVLEN', 'END', 'POS2', 'CHR2', 'set', 'FOUNDBY', 'svdb_origin', 'SUPP_VEC']

    truvari               = false // run TRUVARI merge branch
    // per-sample collapse: DEL/DUP/INV — interval overlap matching (pctsize/pctseq fixed at 0)
    truvari_itvl_refdist  = 10000 // --refdist: max bp distance between SV breakpoints
    truvari_itvl_pctovl   = 0.75  // --pctovl:  min reciprocal overlap fraction
    // per-sample collapse: BND/INS — breakpoint proximity matching (pctovl fixed at 0)
    truvari_bnd_refdist   = 50    // --refdist: max bp distance between breakpoints
    truvari_bnddist       = 50    // --bnddist: max bp distance for BND matching
    truvari_bnd_pctsize   = 0.75  // --pctsize: min size similarity fraction
    truvari_sample_filter = 'INFO/NumConsolidated>0' // keep events detected by ≥2 callers in this sample (NumConsolidated = number of records collapsed into this one)
    truvari_cohort_filter = null // bcftools -i filter applied after cohort merge (null = no filter)

    
}

process {

    shell = ['/bin/bash', '-euo', 'pipefail']
    errorStrategy = { task.attempt <= 3 ? 'retry' : 'finish' }
    maxRetries = 3

    withLabel: samtools  { container = 'quay.io/biocontainers/samtools:1.21--h50ea8bc_0' }
    withLabel: manta     { container = 'quay.io/biocontainers/manta:1.6.0--h9ee0642_1' }
    withLabel: smoove    { container = 'quay.io/biocontainers/smoove:0.2.5--0' }
    withLabel: cnvnator  { container = 'quay.io/biocontainers/cnvnator:0.4.1--h9c7f56d_2' }
    withLabel: delly     { container = 'quay.io/biocontainers/delly:1.7.3--hd6466ae_0' }
    withLabel: dysgu     { container = 'quay.io/biocontainers/dysgu:1.8.8--py313h5d164f8_0' }
    withLabel: bcftools  { container = 'quay.io/biocontainers/bcftools:1.21--h3a4d415_1' }
    withLabel: octopusv  { container = 'quay.io/biocontainers/octopusv:0.3.2--pyhdfd78af_0' }
    withLabel: truvari   { container = 'quay.io/biocontainers/truvari:5.4.0--pyhdfd78af_0' }
    withLabel: bcftools_truvari { container = 'community.wave.seqera.io/library/bcftools_truvari:fbfe0ac5290187e2' }
    withLabel: bcftools_svdb    { container = 'community.wave.seqera.io/library/bcftools_svdb:12db401acbacc624' }
    withLabel: matcha           { container = 'ghcr.io/jemunro/matcha/matcha-bcftools:v26.05.0-rc.2' }
    withLabel: jasminesv { container = 'quay.io/biocontainers/jasminesv:1.1.5--hdfd78af_0' }

    withLabel:C2M2T2 {
        cpus   =   2
        memory = { 2  * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 2  * (2 ** (task.attempt - 1)) + ' h'  }
    }

    withLabel:C2M2T8 {
        cpus   =   2
        memory = { 2  * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 8  * (2 ** (task.attempt - 1)) + ' h'  }
    }

    withLabel:C2M4T4 {
        cpus   =   2
        memory = { 4  * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 4  * (2 ** (task.attempt - 1)) + ' h'  }
    }

    withLabel:C2M4T24 {
        cpus   =   2
        memory = { 4  * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 24  * (2 ** (task.attempt - 1)) + ' h'  }
    }

    withLabel:C2M8T8 {
        cpus   =   2
        memory = { 8  * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 8  * (2 ** (task.attempt - 1)) + ' h'  }
    }

    withLabel:C2M16T8 {
        cpus   =   2
        memory = { 16 * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 4  * (2 ** (task.attempt - 1)) + ' h'  }
    }

    withLabel:C4M8T8 {
        cpus   =   4
        memory = { 16 * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 4  * (2 ** (task.attempt - 1)) + ' h'  }
    }

    withLabel:C4M16T4 {
        cpus   =   4
        memory = { 16 * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 4  * (2 ** (task.attempt - 1)) + ' h'  }
    }

    withLabel:C16M32T4 {
        cpus   =  16
        memory = { 32 * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 4  * (2 ** (task.attempt - 1)) + ' h'  }
    }

    withLabel:C8M16T48 {
        cpus   =   8
        memory = { 16 * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 48 * (2 ** (task.attempt - 1)) + ' h'  }
    }

}

profiles {

    test {
        trace {
            enabled = true
            overwrite = true
            file    = 'trace.txt'
        }
        process {
            errorStrategy  = 'terminate'
            maxRetries     = 0
            cache          = 'lenient'
            resourceLimits = [cpus: 2, memory: '6 GB', time: '8 h']
        }
        executor {
            cpus   = 12
            memory = '6 GB'
        }
        params {
            id        = 'test'
            ped       = "${projectDir}/test/fixtures/test_fam.ped"
            bams      = "${projectDir}/test/fixtures/test_fam.bams"
            ref_fasta = "${projectDir}/test/fixtures/hg19.chr20.fa.gz"
            assembly  = 'hg19'
            callers   = ['MANTA', 'DYSGU', 'SMOOVE', 'DELLY', 'DELLY_CNV', 'CNVNATOR']
            chrs      = ['20']
            outdir    = "${projectDir}/test/output"
            svdb = false
            truvari = false
        }
        process {
            cpus   = 2
            memory = '4 GB'
            time   = '2 h'
        }
    }

    conda {
        conda.enabled  = true
        singularity.enabled = false
        apptainer.enabled = false
        docker.enabled = false
        // conda.useMamba = true
        process {
            conda = "${projectDir}/environment.yml"
            withLabel: 'manta'    { conda = 'bioconda::manta=1.6.0' }
            withLabel: 'smoove'   { conda = 'bioconda::smoove=0.2.8' }
            withLabel: 'cnvnator' { conda = 'bioconda::cnvnator=0.4.1' }
            withLabel: 'delly'    { conda = 'bioconda::delly=1.7.3' }
            withLabel: 'dysgu'    { conda = 'bioconda::dysgu=1.8.8' }
            withLabel: 'octopusv' { conda = 'bioconda::octopusv=0.3.2' }
        }
    }

}
