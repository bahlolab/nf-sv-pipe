
process {

    shell = ['/bin/bash', '-euo', 'pipefail']
    errorStrategy = { task.attempt <= 3 && task.errorCount < 10 ? 'retry' : 'finish' }
    maxRetries = 3

    container = 'bahlolab/sv-pipe:22.02.1'

    withLabel: QDNASEQ {
        container = 'bahlolab/sv-pipe-qdnaseq:dev'
    }

    withLabel: bedtools {
        container = 'quay.io/biocontainers/bedtools:2.27.1--h077b44d_9'
    }

    withLabel: cnvnator {
        container = 'quay.io/biocontainers/cnvnator:0.4.1--h9c7f56d_2'
    }

    withLabel: mosdepth {
        container = 'quay.io/biocontainers/mosdepth:0.3.12--h0ec343a_0'
    }

    withLabel: samtools {
        container = 'quay.io/biocontainers/samtools:1.23--h96c455f_0'
    }

    withLabel:C1M1T1 {
        cpus   =   1
        memory = { 1 * task.attempt + ' GB' }
        time   = { 1 * task.attempt + ' h'  }
    }

    withLabel:C2M2T2 {
        cpus   =   2
        memory = { 2 * task.attempt + ' GB' }
        time   = { 2 * task.attempt + ' h'  }
    }

    withLabel:C2M2T8 {
        cpus   =   2
        memory = { 2 * task.attempt + ' GB' }
        time   = { 8 * task.attempt + ' h'  }
    }

    withLabel:C2M4T4 {
        cpus   =   2
        memory = { 4 * task.attempt + ' GB' }
        time   = { 4 * task.attempt + ' h'  }
    }

    withLabel:C2M16T4 {
        cpus   =   2
        memory = { 16 * task.attempt + ' GB' }
        time   = { 4 * task.attempt + ' h'  }
    }

}