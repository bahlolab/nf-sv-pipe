
params {
    id        = 'chorus_sv'      // cohort/run name used in output filenames
    outdir    = 'output'
    ped       = ''      // PED file defining samples and family structure
    bams      = ''      // glob or CSV of input BAM/CRAM files
    ref_fasta = ''      // reference genome FASTA (must be indexed)
    assembly  = 'hg38'  // genome build: hg38 or hg19
    chr_prefix = null   // chromosome prefix: null = auto ('chr' for hg38, '' for hg19)
    callers   = ['MANTA', 'DYSGU', 'SMOOVE', 'DELLY', 'DELLY_CNV', 'CNVNATOR']  // callers to run; order sets merge priority
    apply_filters = ['DELLY']  // callers whose BCFs are PASS-filtered (bcftools view -f PASS,.) before MATCHA
    familial  = true    // treat samples grouped by family in PED (joint calling where supported)
    copy_bams = false   // copy BAMs to work dir (needed if input is on slow/remote storage)
    refdir    = 'reference_files'  // storeDir for downloaded reference files (mappability, exclude lists)
    cachedir  = null    // storeDir for cacheable call outputs; null = always re-run
    bin_size  = 1000    // CNVnator bin size (bp)
    chrs      = 'auto'  // chromosomes to process; null = no restriction, 'auto' = autosomes + X/Y with chr_prefix, or a List of names

    matcha_min_jaccard = 0.75  // minimum Jaccard similarity for matcha collapse/merge
    matcha_sample_filter = 'FILTER="PASS" || INFO/N_CALLERS>1' // after per sample collapse, only keep records that PASS or called by multiple callers
}

process {

    shell = ['/bin/bash', '-euo', 'pipefail']
    errorStrategy = { task.attempt <= 3 && task.errorCount < 10 ? 'retry' : 'finish' }
    maxRetries = 3

    withLabel: samtools  { container = 'quay.io/biocontainers/samtools:1.21--h50ea8bc_0' }
    withLabel: manta     { container = 'quay.io/biocontainers/manta:1.6.0--h9ee0642_1' }
    withLabel: smoove    { container = 'quay.io/biocontainers/smoove:0.2.5--0' }
    withLabel: cnvnator  { container = 'quay.io/biocontainers/cnvnator:0.4.1--h9c7f56d_2' }
    withLabel: delly     { container = 'quay.io/biocontainers/delly:1.7.3--hd6466ae_0' }
    withLabel: dysgu     { container = 'quay.io/biocontainers/dysgu:1.8.8--py313h5d164f8_0' }
    withLabel: bcftools  { container = 'quay.io/biocontainers/bcftools:1.21--h3a4d415_1' }
    withLabel: octopusv  { container = 'quay.io/biocontainers/octopusv:0.3.2--pyhdfd78af_0' }
    withLabel: truvari   { container = 'quay.io/biocontainers/truvari:5.4.0--pyhdfd78af_0' }
    withLabel: jasminesv { container = 'quay.io/biocontainers/jasminesv:1.1.5--hdfd78af_0' }

    withLabel:C2M2T2 {
        cpus   =   2
        memory = { 2  * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 2  * (2 ** (task.attempt - 1)) + ' h'  }
    }

    withLabel:C2M2T8 {
        cpus   =   2
        memory = { 2  * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 8  * (2 ** (task.attempt - 1)) + ' h'  }
    }

    withLabel:C2M4T4 {
        cpus   =   2
        memory = { 4  * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 4  * (2 ** (task.attempt - 1)) + ' h'  }
    }

    withLabel:C2M4T16 {
        cpus   =   2
        memory = { 4  * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 16  * (2 ** (task.attempt - 1)) + ' h'  }
    }

    withLabel:C2M8T8 {
        cpus   =   2
        memory = { 8  * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 8  * (2 ** (task.attempt - 1)) + ' h'  }
    }

    withLabel:C2M16T4 {
        cpus   =   2
        memory = { 16 * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 4  * (2 ** (task.attempt - 1)) + ' h'  }
    }

    withLabel:C4M8T8 {
        cpus   =   4
        memory = { 16 * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 4  * (2 ** (task.attempt - 1)) + ' h'  }
    }

    withLabel:C4M16T4 {
        cpus   =   4
        memory = { 16 * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 4  * (2 ** (task.attempt - 1)) + ' h'  }
    }

    withLabel:C8M16T48 {
        cpus   =   8
        memory = { 16 * (2 ** (task.attempt - 1)) + ' GB' }
        time   = { 48 * (2 ** (task.attempt - 1)) + ' h'  }
    }

}

profiles {

    test {
        trace {
            enabled = true
            overwrite = true
            file    = 'trace.txt'
        }
        process {
            errorStrategy  = 'terminate'
            maxRetries     = 0
            cache          = 'lenient'
            resourceLimits = [cpus: 2, memory: '6 GB', time: '8 h']
        }
        executor {
            cpus   = 12
            memory = '6 GB'
        }
        params {
            id        = 'test'
            ped       = "${projectDir}/test/fixtures/test_fam.ped"
            bams      = "${projectDir}/test/fixtures/test_fam.bams"
            ref_fasta = "${projectDir}/test/fixtures/hg19.chr20.fa.gz"
            assembly  = 'hg19'
            callers   = ['MANTA', 'DYSGU', 'SMOOVE', 'DELLY', 'DELLY_CNV', 'CNVNATOR']
            chrs      = ['20']
            outdir    = "${projectDir}/test/output"
        }
        process {
            cpus   = 2
            memory = '4 GB'
            time   = '2 h'
        }
    }

    conda {
        conda.enabled  = true
        singularity.enabled = false
        apptainer.enabled = false
        docker.enabled = false
        // conda.useMamba = true
        process {
            conda = "${projectDir}/environment.yml"
            withLabel: 'manta'    { conda = 'bioconda::manta=1.6.0' }
            withLabel: 'smoove'   { conda = 'bioconda::smoove=0.2.8' }
            withLabel: 'cnvnator' { conda = 'bioconda::cnvnator=0.4.1' }
            withLabel: 'delly'    { conda = 'bioconda::delly=1.7.3' }
            withLabel: 'dysgu'    { conda = 'bioconda::dysgu=1.8.8' }
            withLabel: 'octopusv' { conda = 'bioconda::octopusv=0.3.2' }
        }
    }

}
